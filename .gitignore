# Generated by Cargo
# will have compiled files and executables
debug/
target/

# Remove Cargo.lock from gitignore if creating an executable, leave it for libraries
# More information here https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which can generally be ignored
*.pdb
*.rs.user
*.lib
*.exp

# macOS
.DS_Store

# IDEs
.idea/
.vscode/
*.swp
*.swo

# distribution
dist/
build/

# local conda environment (icon tools)
.conda_env/

# generated iconset (derived from SVG)
assets/*.iconset/
assets/*.icns

# ==========================================
# Data, Outputs, and Temporary Files
# ==========================================

# Temporary / Scratch scripts in root
scratch*.rs
isc_form.html

# Seismic data formats
*.mseed
*.SAC
*.sac

# Scientific / binary data
*.npz

# Output files & exported plots
*.csv
*.jsonl
*.dat
*.out
*.log
*.png

# Allow assets to be tracked despite global rules
!assets/*.png
!assets/*.svg

# Local Test & Unused directories 
# (Hapus tanda pagar di bawah jika Anda tidak ingin melacak folder ini sama sekali)
test_files/
test_data/
test_isc/
unused/
examples/